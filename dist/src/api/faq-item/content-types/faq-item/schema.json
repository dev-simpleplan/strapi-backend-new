{
    "kind": "collectionType",
    "collectionName": "faq_items",
    "info": {
        "singularName": "faq-item",
        "pluralName": "faq-items",
        "displayName": "FAQ Item"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "question": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "question"
        },
        "answer": {
            "type": "blocks",
            "required": true
        },
        "short_answer": {
            "type": "text"
        },
        "sort_order": {
            "type": "integer"
        },
        "category": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::faq-category.faq-category",
            "inversedBy": "faq_item"
        },
        "seo": {
            "type": "component",
            "component": "shared.seo",
            "repeatable": false
        }
    }
}
